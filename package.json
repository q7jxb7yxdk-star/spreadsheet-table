    "@types/node": "^22.15.34",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0"
  }
